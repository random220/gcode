#!/usr/bin/env bash
set -euo pipefail

# ==================== Config ====================
SSH_MARKER="# TAILSCALE"
SSH_USER="om"
BIN_DIR="$HOME/bin"
GO_BIN="$HOME/go/bin"

# Proxy is disabled by default (macOS + normal Linux)
PROXYLINE='# ProxyCommand ncat --proxy 127.0.0.1:1055 --proxy-type socks5 -w 30 %h %p'

log() { echo "==> $1"; }
die() { echo "ERROR: $1" >&2; exit 1; }
has() { command -v "$1" >/dev/null 2>&1; }

install_tailscale_mac() {
    has brew || /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || true)"
    has go || brew install go

    mkdir -p ~/sb && cd ~/sb
    [[ -d tailscale ]] && (cd tailscale && git pull) || git clone https://github.com/tailscale/tailscale.git
    cd tailscale && go install tailscale.com/cmd/tailscale{,d}

    sudo "$GO_BIN/tailscaled" install-system-daemon
    "$GO_BIN/tailscale" up
}

setup_socks5() {
    log "Falling back to userspace networking + SOCKS5 proxy..."
    if ! has ncat; then
        has dnf && sudo dnf -y install nmap-ncat ||
        has apt-get && (sudo apt-get update -qq && sudo apt-get install -y ncat) ||
        die "No supported package manager for ncat."
    fi

    mkdir -p "$BIN_DIR"
    cat > "$BIN_DIR/retail" <<'EOF'
#!/usr/bin/env bash
sudo pkill -9 tailscaled 2>/dev/null || true
sudo tailscaled --tun=userspace-networking --socks5-server=localhost:1055 &

# Wait for daemon readiness
for i in {1..20}; do
    sleep 0.2
    if tailscale status >/dev/null 2>&1; then
        break
    fi
done

sudo tailscale up
EOF
    chmod +x "$BIN_DIR/retail"
    [[ ":$PATH:" != *":$BIN_DIR:"* ]] && export PATH="$BIN_DIR:$PATH"
    "$BIN_DIR/retail"

}

install_tailscale_linux() {
    if ! curl -fsSL https://tailscale.com/install.sh | sh; then
        log "Installer exited non-zero (expected in containers). Continuing..."
    fi
    has tailscale || die "Tailscale binary missing after installation attempt."
    sudo tailscale up || setup_socks5
}

update_ssh_config() {
    local ip
    ip=$(tailscale ip tron 2>/dev/null | head -n1 | tr -d '[:space:]')

    [[ -n "$ip" ]] || die "'tron' not found in Tailscale IP list."

    log "Found tron at $ip"

    sed "/${SSH_MARKER} begin/,/${SSH_MARKER} end/d" ~/.ssh/config > ~/.ssh/config.tmp 2>/dev/null || true

    # Enable proxy only for userspace mode
    PROXYLINE='ProxyCommand ncat --proxy 127.0.0.1:1055 --proxy-type socks5 -w 30 %h %p'
    if tailscale status --json|grep TUN | grep true; then
        PROXYLINE='# ProxyCommand ncat --proxy 127.0.0.1:1055 --proxy-type socks5 -w 30 %h %p'
    fi

    cat >> ~/.ssh/config.tmp << EOF
${SSH_MARKER} begin
Host tron *.ts.net 100.*
    ${PROXYLINE}
    ServerAliveInterval 60
    ServerAliveCountMax 5
    StrictHostKeyChecking accept-new
    UserKnownHostsFile /dev/null

Host tron
    User ${SSH_USER}
    Hostname ${ip}
    IdentityFile ~/.ssh/id_ed25519
${SSH_MARKER} end
EOF

    mv ~/.ssh/config.tmp ~/.ssh/config
    chmod 600 ~/.ssh/config
    log "Updated ~/.ssh/config"
}

# ==================== Main ====================
case "$(uname)" in
    Darwin)
        export PATH="$GO_BIN:$PATH"
        has tailscale || install_tailscale_mac
        tailscale status || { "$GO_BIN/tailscale" up && tailscale status; }
        ;;
    Linux)
        has tailscale || install_tailscale_linux
        tailscale status || { install_tailscale_linux && tailscale status; }
        ;;
    *)
        die "Unsupported OS: $(uname)"
        ;;
esac

update_ssh_config
log "Tailscale setup completed successfully!"
echo
