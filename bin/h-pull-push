#!/bin/bash

# ~/.ssh/config
# Host home_dns
#     User om
#     Hostname crondite.duckdns.org
#     IdentityFile ~/.ssh/id_rsa
# 
# Host home_localip
#     User om
#     Hostname 192.168.10.180
#     IdentityFile ~/.ssh/id_rsa
# 

umask 077
bindir=$(cd "$(dirname "$(readlink -f "$0")")" && pwd -P)
tmpdir=$(mktemp -d)
server_ip=''
server_name=''
verb=''
direction=''
SRC=''
DST=''

main() {
    determine_server
    mk_sshconfig
    determine_direction
    mount_local
    mount_remote
    do_sync
    get_out 0 '!!! Should never come here !!!'
}

mount_local() {
    vmount
    [[ -d ~/b/om/p/CRUZER ]] || get_out 1 "ERROR Not found: $HOME/b/om/p/CRUZER"
}

determine_server() {
    local destinations=( \
      192.168.10.180:22:nuc \
      192.168.10.101:22:tron101 \
      192.168.10.178:22:tron178 \
    )
    # $ which tailscale
    # /Users/zk/go/bin/tailscale)
    local tailscale=$(which tailscale)
    if [[ $tailscale != '' ]]; then
        local ip=$(tailscale status | grep ' tron ' | awk '{print $1}')
        if [[ $ip != '' ]]; then
            destinations=("${destinations[@]}" "$ip:22:tront")
        fi
    fi

    local destination
    for destination in "${destinations[@]}"; do
        IFS=: read -r server_ip server_port server_name <<< "$destination"
        ping -W 3 -c 2 $server_ip
        if [[ $? == 0 ]]; then
            break
        fi
        server_name='cron'
        server_ip='76.236.30.161'
        server_port='22'
    done
}

mk_sshconfig () {
    mkdir -p ~/.ssh/hpull
    cat <<EOF >~/.ssh/hpull/config
StrictHostKeyChecking=no
CheckHostIP=no
EscapeChar=~
UserKnownHostsFile=/dev/null
LogLevel ERROR

Host $server_name
    User om
    HostName $server_ip
    Port $server_port
    ControlPath ~/.ssh/hpull/ctrl-%l-to-%h
    ControlMaster auto
    ControlPersist 10m
    ServerAliveInterval 180
    GatewayPorts yes

EOF

}

determine_direction () {
    case "$(basename "$0")" in
        'hpull')
          verb=PULL
          direction='from'
          SRC="$server_name:b/om/p/CRUZER/CRUZER"
          DST="$HOME/b/om/p/CRUZER/CRUZER"
          ;;
        'hpush')
          verb=PUSH
          direction='to'
          DST="$server_name:b/om/p/CRUZER/CRUZER"
          SRC="$HOME/b/om/p/CRUZER/CRUZER"
          ;;
        *)
          echo 'Error: Must be hpull or hpush'
          exit 1
          ;;
    esac

    printf "$verb $direction $server_name ? (y/n): "
    local yesno
    read yesno
    if [[ $yesno == 'y' ]]; then
        :
    else
        exit 1
    fi
}


bailout() {
    echo "$1"
    exit 1
}

mount_remote() {
    ssh -F ~/.ssh/hpull/config $server_name 'echo CONNECTED' || bailout "Error: $server_name Connection failed"
    ssh -F ~/.ssh/hpull/config -t $server_name 'vmount'
    ssh -F ~/.ssh/hpull/config -t $server_name '[[ -d ~/b/om/p/CRUZER ]]' >/dev/null 2>&1 || get_out 1 "Error: Remote dir not found ~/b/om/p/CRUZER"
}

do_sync() {
    echo
    echo "Syncing ..."

    #TZ=UTC rsync -e "ssh -F $HOME/.ssh/hpull/config" -a "$SRC"/ >"$tmpdir/list_SRC.txt"
    #TZ=UTC rsync -e "ssh -F $HOME/.ssh/hpull/config" -a "$DST"/ >"$tmpdir/list_DST.txt"

    local cmd

    cmd="TZ=UTC rsync -e 'ssh -F $HOME/.ssh/hpull/config' -a '$SRC'/ >'$tmpdir/list_SRC.txt'"
    echo "doing: $cmd"
    eval $cmd

    cmd="TZ=UTC rsync -e 'ssh -F $HOME/.ssh/hpull/config' -a '$DST'/ >'$tmpdir/list_DST.txt'"
    echo "doing: $cmd"
    eval $cmd


    cmd="$bindir/rsync_list_normalize < '$tmpdir/list_SRC.txt' >'$tmpdir/list_norm_SRC.txt'"
    echo "doing: $cmd"
    eval $cmd

    cmd="$bindir/rsync_list_normalize < '$tmpdir/list_DST.txt' >'$tmpdir/list_norm_DST.txt'"
    echo "doing: $cmd"
    eval $cmd

    cmd="diff -u '$tmpdir/list_norm_DST.txt' '$tmpdir/list_norm_SRC.txt' >'$tmpdir/diff.txt'"
    echo "doing: $cmd"
    eval $cmd
    exit_status=$?

    if [[ $exit_status == 0 ]]; then
        get_out 0
    fi

    cmd="egrep -v 'gitted/sandbox/\.git/' <'$tmpdir/diff.txt'"
    echo "doing: $cmd"
    eval $cmd

    if [[ $exit_status != 0 ]]; then
        echo
        echo
        echo
        echo
        printf "Again, $verb $direction $server_name? (YES/n): "
        read yesno
        if [[ $yesno == 'YES' ]]; then
            cmd="rsync -e 'ssh -F $HOME/.ssh/hpull/config' --exclude=".DS_Store" -a --delete '$SRC'/ '$DST'/"
            echo "doing: $cmd"
            eval $cmd
            exit_status=$?
        else
            get_out 0
        fi
    fi

    get_out $exit_status

}

get_out() {
    local status=$1
    local cmd="rm -rf '$tmpdir'"
    echo "doing: $cmd"
    eval $cmd

    ssh -F ~/.ssh/hpull/config -O check $server_name
    if [[ $? == 0 ]]; then
        ssh -F ~/.ssh/hpull/config $server_name 'vumount'
        ssh -F ~/.ssh/hpull/config -O exit $server_name
    fi

    exit $status
}


main
