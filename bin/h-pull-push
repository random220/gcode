#!/usr/bin/env bash
# hpull / hpush - Sync CRUZER directory between local and remote host

set -o errexit
set -o nounset
set -o pipefail

umask 077

bindir="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd -P)"
tmpdir=$(mktemp -d)
trap 'cleanup' EXIT

server_ip=''
server_port='22'
server_name='cron'
fallback_ip='76.236.30.161'

cleanup() {
    rm -rf "$tmpdir" 2>/dev/null || true

    # Close SSH control master gracefully
    if ssh -F ~/.ssh/hpull/config -O check "$server_name" &>/dev/null; then
        ssh -F ~/.ssh/hpull/config "$server_name" 'vumount' 2>/dev/null || true
        ssh -F ~/.ssh/hpull/config -O exit "$server_name" 2>/dev/null || true
    fi
}

bailout() {
    echo "ERROR: $1" >&2
    exit 1
}

determine_server() {
    local destinations=(
        "192.168.10.180:22:nuc"
        "192.168.10.101:22:tron101"
        "192.168.10.178:22:tron178"
    )

    # Add Tailscale Tron if available and reachable
    if command -v tailscale >/dev/null 2>&1; then
        local ts_ip
        ts_ip=$(tailscale status 2>/dev/null | awk '$2 == "tron" {print $1; exit}')
        [[ -n "$ts_ip" ]] && destinations+=("$ts_ip:22:tront")
    fi

    local dest
    for dest in "${destinations[@]}"; do
        IFS=: read -r server_ip server_port server_name <<< "$dest"

        if ping -W 3 -c 2 "$server_ip" &>/dev/null; then
            echo "✓ Reachable: $server_name ($server_ip)"
            return 0
        fi
    done

    # Fallback to public IP
    server_ip="$fallback_ip"
    server_port='22'
    server_name='cron'
    echo "Using fallback server: $server_name ($server_ip)"
}

mk_sshconfig() {
    mkdir -p ~/.ssh/hpull

    cat > ~/.ssh/hpull/config <<EOF
StrictHostKeyChecking=no
CheckHostIP=no
EscapeChar=~
UserKnownHostsFile=/dev/null
LogLevel=ERROR

Host $server_name
    User om
    HostName $server_ip
    Port $server_port
    ControlPath ~/.ssh/hpull/ctrl-%l-to-%h
    ControlMaster auto
    ControlPersist 10m
    ServerAliveInterval 180
    GatewayPorts yes
EOF
}

determine_direction() {
    local scriptname
    scriptname="$(basename "$0")"

    case "$scriptname" in
        hpull)
            verb="PULL"
            direction="from"
            SRC="$server_name:b/om/p/CRUZER/CRUZER"
            DST="$HOME/b/om/p/CRUZER/CRUZER"
            ;;
        hpush)
            verb="PUSH"
            direction="to"
            DST="$server_name:b/om/p/CRUZER/CRUZER"
            SRC="$HOME/b/om/p/CRUZER/CRUZER"
            ;;
        *)
            bailout "Script must be called as 'hpull' or 'hpush'"
            ;;
    esac

    printf "%s %s %s? (y/n): " "$verb" "$direction" "$server_name"
    read -r yesno
    [[ "$yesno" == "y" ]] || exit 1
}

mount_local() {
    vmount
    [[ -d ~/b/om/p/CRUZER ]] || bailout "Local directory not found: ~/b/om/p/CRUZER"
}

mount_remote() {
    ssh -F ~/.ssh/hpull/config "$server_name" 'echo CONNECTED' \
        || bailout "Failed to connect to $server_name"

    ssh -F ~/.ssh/hpull/config -t "$server_name" 'vmount'

    if ! ssh -F ~/.ssh/hpull/config "$server_name" '[[ -d ~/b/om/p/CRUZER ]]' &>/dev/null; then
        bailout "Remote directory not found: ~/b/om/p/CRUZER"
    fi
}

do_sync() {
    echo
    echo "=== Syncing $verb $direction $server_name ==="

    # Generate directory listings (the bugfix you mentioned)
    TZ=UTC rsync -e "ssh -F $HOME/.ssh/hpull/config" -a "$SRC"/ > "$tmpdir/list_SRC.txt"
    TZ=UTC rsync -e "ssh -F $HOME/.ssh/hpull/config" -a "$DST"/ > "$tmpdir/list_DST.txt"

    "$bindir/rsync_list_normalize" < "$tmpdir/list_SRC.txt" > "$tmpdir/list_norm_SRC.txt"
    "$bindir/rsync_list_normalize" < "$tmpdir/list_DST.txt" > "$tmpdir/list_norm_DST.txt"

    if diff -u "$tmpdir/list_norm_DST.txt" "$tmpdir/list_norm_SRC.txt" > "$tmpdir/diff.txt"; then
        echo "Directories are already in sync."
        return 0
    fi

    # Show relevant differences
    echo
    egrep -v 'gitted/sandbox/\.git/' "$tmpdir/diff.txt" || true

    printf "\n\nPerform actual %s %s %s? Type YES to confirm: " "$verb" "$direction" "$server_name"
    read -r yesno

    if [[ "$yesno" == "YES" ]]; then
        echo "Running rsync..."
        rsync -e "ssh -F $HOME/.ssh/hpull/config" \
              --exclude=".DS_Store" \
              -a --delete \
              "$SRC"/ "$DST"/
        local exit_status=$?
        echo "Sync finished with exit status: $exit_status"
        return "$exit_status"
    else
        echo "Sync cancelled by user."
        return 0
    fi
}

main() {
    determine_server
    mk_sshconfig
    determine_direction
    mount_local
    mount_remote
    do_sync
}

main "$@"
