#!/bin/bash
source "$(dirname "$0")/config.sh"

gcloud compute instances create "$VM_NAME" \
    --project="$PROJECT" \
    --zone="$ZONE" \
    --machine-type="$MACHINE_TYPE" \
    --image-family="$IMAGE_FAMILY" \
    --image-project="$IMAGE_PROJECT" \
    --tags="$TAGS"

cat <<EOF >/dev/null

gcloud compute firewall-rules list --project=myfree-501315 2>/dev/null | grep NAME

gcloud compute firewall-rules create allow8484 --quiet \
   --project=myfree-501315 \
   --direction=INGRESS \
   --priority=1000 \
   --network=default \
   --action=ALLOW \
   --rules=tcp:8484 \
   --source-ranges=0.0.0.0/0

gcloud compute firewall-rules delete allow8484 --quiet --project=myfree-501315

EOF
