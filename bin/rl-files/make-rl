#!/bin/bash

# Default container name
h=rl

show_help() {
    cat <<EOF
Usage: rl [-c <container_name>] [-h|--help] [command]
       rl [-c <container_name>] 0

A launcher/wrapper script for managing Rocky Linux 9-based Docker development containers.

Options:
  -c <name>   Specify a custom container name (defaults to 'rl').
  -h, --help  Show this help message and exit.

Arguments:
  0           If the first argument after options is '0', the container (and local image) will be cleaned up/removed.
  [command]   Optional command to run inside the container. If omitted, starts an interactive bash shell.

SSH Access:
  The script automatically configures Host SSH keys and appends an entry to your ~/.ssh/config.
  Once the container is running, you can connect directly using:
      ssh <container_name>

EOF
}

# Parse options
ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -c)
            if [[ -n "$2" ]]; then
                h="$2"
                shift 2
            else
                echo "Error: -c requires a container name." >&2
                exit 1
            fi
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

# Re-set positional parameters
set -- "${ARGS[@]}"

ensure_docker_running() {
    if [[ $(uname) == 'Darwin' ]]; then
        docker ps -a >/dev/null 2>&1 && return
        docker desktop status >/dev/null 2>&1 || docker desktop start
        docker desktop status >/dev/null 2>&1 || exit 1
    fi
}
ensure_docker_running

find_free_port() {
    local base_port=$1
    local port=$base_port
    if [[ "$h" == "rl" ]]; then
        echo "$base_port"
        return
    fi

    # If it's the SSH port (3022), check ssh config first for persistence
    if [[ $base_port -eq 3022 ]]; then
        local existing_port=$(awk -v host="$h" '
            tolower($1) == "host" && $2 == host {found=1; next}
            tolower($1) == "host" {found=0}
            found && tolower($1) == "port" {print $2; exit}
        ' ~/.ssh/config 2>/dev/null)
        if [[ -n "$existing_port" ]]; then
            echo "$existing_port"
            return
        fi
        # Start searching from 3023 for other containers
        port=3023
    fi
    while true; do
        # Check if port is in ssh config
        if grep -E "^[ \t]*Port[ \t]+$port$" ~/.ssh/config >/dev/null 2>&1; then
            ((port++))
            continue
        fi
        # Check if port is already mapped in docker ps
        if docker ps --format '{{.Ports}}' | grep -E "(^|:)$port->" >/dev/null 2>&1; then
            ((port++))
            continue
        fi
        # Check if port is in use on the host system
        if ss -tln 2>/dev/null | grep -q ":$port " >/dev/null 2>&1 || nc -z 127.0.0.1 "$port" >/dev/null 2>&1; then
            ((port++))
            continue
        fi
        echo "$port"
        return
    done
}

ssh_port=$(find_free_port 3022)

runit() {
    if [[ "$1" == '' ]] || [[ "$1" == '0'  ]] ; then
        docker exec -it -u om -w /home/om $h bash
    else
        docker exec -it -u om -w /home/om $h "$@"
    fi
}

if [[ "$1" == '0' ]]; then
    docker rm -f $h
    docker rmi -f myrl
fi



docker inspect $h > /dev/null 2>&1

if [ $? -eq 0 ]; then
    docker start $h
    runit "$@"
    exit 0
fi

docker image inspect myrl > /dev/null 2>&1
if [ $? -ne 0 ]; then
    if [[ -f ~/myrl.tgz ]]; then
        docker load < ~/myrl.tgz
    else
        docker build -t myrl .
        docker save -o ~/myrl.tar myrl
        gzip ~/myrl.tar
        mv ~/myrl.tar.gz ~/myrl.tgz
    fi
fi

docker network inspect day0 >/dev/null 2>&1 || docker network create day0
echo "Creating container '$h' mapping Host SSH port $ssh_port -> 22..."
docker run --network day0 -itd --name $h -h $h -p $ssh_port:22 myrl

umask 077
keydir="$HOME/.ssh/rl_$h"
if [[ ! -f "$keydir/id_rsa" ]]; then
    mkdir -p "$keydir"
    ssh-keygen -t rsa -b 4096 -N '' -f "$keydir/id_rsa"
fi
docker cp "$keydir/id_rsa.pub" $h:/tmp/pubkey

egrep "^Host[ \t]+$h$" ~/.ssh/config >/dev/null 2>&1
if [[ $? != 0 ]]; then
    cat <<EOF >>~/.ssh/config

Host $h
    Hostname 0.0.0.0
    Port $ssh_port
    User om
    IdentityFile ~/.ssh/rl_$h/id_rsa

EOF
fi

#    -v ~/:/home/om/h \

if [[ -d ~/gcode ]]; then

    docker cp -a ~/gcode/ $h:/tmp/

    cat <<"EOF" | docker exec -u root -i $h bash -
set -x
umask 077
mkdir -p /home/om/.ssh
mv /tmp/pubkey /home/om/.ssh/authorized_keys
[[ -d /home/om/gcode ]] && {
  mv /home/om/gcode /home/om/gcode.x
  rm -rf /home/om/gcode.x &
}
mv /tmp/gcode /home/om/gcode
chown -R om:om /home/om/gcode /home/om/.ssh
EOF

    cat <<"EOF" | docker exec -i -u om -w /home/om $h bash -
. gcode/bin/gcode.0
. .bashrc
gits

EOF

fi

runit "$@"
