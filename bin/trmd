#!/usr/bin/env bash
# trmd-start — launch transmission-daemon inside tmux, with a VPN watchdog
set -euo pipefail

readonly PROG="${0##*/}"
readonly TMUX_SESSION="trmd"
readonly WATCHDOG_SESSION="trmd-watchdog"
readonly VPN_IFACE="tun0"
readonly WATCHDOG_INTERVAL=5  # seconds between VPN checks

readonly TRM_CONFIG_DIR="${HOME}/.config/transmission"
readonly TRM_ROOT="${HOME}/Downloads/uu"
readonly TRM_TORRENTS_IN="${TRM_ROOT}/t_"
readonly TRM_DOING="${TRM_ROOT}/doing_"
readonly TRM_DONE="${TRM_ROOT}/done_"
readonly TRM_PID="${TRM_ROOT}/PID"



cd "${HOME}"
umask 077

# ---------------------------------------------------------------------------
# usage / help
# ---------------------------------------------------------------------------
usage() {
    cat <<EOF
Usage: $PROG [-h]

Start transmission-daemon inside a tmux session and launch a watchdog that
monitors the VPN tunnel interface ($VPN_IFACE). If the tunnel disappears,
the watchdog shuts transmission-daemon down gracefully.

What this script does:
  1. Shuts down any previously running transmission-daemon + tmux sessions
  2. Ensures ~/Downloads/uu is mounted via sshfs from mom:Downloads/uu
  3. Starts transmission-daemon (tmux session: $TMUX_SESSION)
  4. Starts a VPN watchdog loop  (tmux session: $WATCHDOG_SESSION)
     — polls $VPN_IFACE every ${WATCHDOG_INTERVAL}s
     — calls 'transmission-remote --exit' if the interface vanishes

Directory layout:

Options:
  -h, --help    Show this help message and exit
EOF
}

# ---------------------------------------------------------------------------
# helpers
# ---------------------------------------------------------------------------

log()  { echo "[$PROG] $*" >&2; }
die()  { echo "[$PROG] ERROR: $*" >&2; exit 1; }

vpn_is_up() {
    ip link show "${VPN_IFACE}" &>/dev/null
}

# mount_source DIR — print the filesystem source (device/host) for DIR
mount_source() {
    (cd "$1" && df -kh . 2>/dev/null) | tail -1 | awk '{print $1}'
}

# is_sshfs_mount DIR — true if DIR is already mounted via sshfs (source has ':')
is_sshfs_mount() {
    [[ "$(mount_source "$1")" == *:* ]]
}

# ---------------------------------------------------------------------------
# sub-routines
# ---------------------------------------------------------------------------

kill_previous() {
    log "Shutting down previous instance (if any)…"
    transmission-remote --exit 2>/dev/null || true
    sleep 1
    tmux kill-session -t "${TMUX_SESSION}"       2>/dev/null || true
    tmux kill-session -t "${WATCHDOG_SESSION}"   2>/dev/null || true
}

ensure_mounts() {
    log "Ensuring directories exist…"

    if is_sshfs_mount "${TRM_ROOT}"; then
        log "${TRM_ROOT} is already sshfs-mounted, skipping."
        return
    fi


    log "Mounting mom:Downloads/uu → ${TRM_ROOT}…"
    ssh mom 'mkdir -p ~/Downloads/uu'
    mkdir -p "$TRM_ROOT"
    sshfs mom:Downloads/uu "${TRM_ROOT}"

    # verify
    is_sshfs_mount "${TRM_ROOT}" \
        || die "Mount failed on ${TRM_ROOT}"
    log "Mount OK."

    mkdir -p \
        $TRM_CONFIG_DIR \
        $TRM_TORRENTS_IN \
        $TRM_DOING \
        $TRM_DONE
}

start_daemon() {
    log "Starting transmission-daemon (tmux session: ${TMUX_SESSION})…"
    tmux new-session -s "${TMUX_SESSION}" -d \
        transmission-daemon \
            --foreground \
            --encryption-required \
            --dht \
            --utp \
            --config-dir ${TRM_CONFIG_DIR} \
            --watch-dir ${TRM_TORRENTS_IN} \
            --incomplete-dir ${TRM_DOING} \
            --download-dir ${TRM_DONE} \
            --pid-file ${TRM_PID}
}

start_watchdog() {
    log "Starting VPN watchdog (tmux session: ${WATCHDOG_SESSION}, iface: ${VPN_IFACE})…"

    # Embed the watchdog loop as a here-doc passed to bash so all variables
    # are resolved now, not at execution time inside the child shell.
    local watchdog_script
    watchdog_script=$(cat <<WATCHDOG
#!/usr/bin/env bash
set -x
readonly VPN_IFACE="${VPN_IFACE}"
readonly INTERVAL=${WATCHDOG_INTERVAL}

echo "[watchdog] started — monitoring \${VPN_IFACE} every \${INTERVAL}s"
while true; do
    sleep "\${INTERVAL}"
    if ! ip link show "\${VPN_IFACE}" &>/dev/null; then
        echo "[watchdog] \$(date -Iseconds): \${VPN_IFACE} is gone — shutting down transmission-daemon"
        transmission-remote --exit 2>/dev/null || true
        echo "[watchdog] Done. Exiting watchdog."
        exit 0
    fi
	tmux list-sessions -F '#S' 2>/dev/null | grep -Fxq "${TMUX_SESSION}" || {
		echo "[watchdog] TMUX_SESSION went away. Exiting watchdog."
		exit 0
	}
done
WATCHDOG
)

    tmux new-session -s "${WATCHDOG_SESSION}" -d bash -c "${watchdog_script}"
}

# ---------------------------------------------------------------------------
# entry point
# ---------------------------------------------------------------------------

case "${1-}" in
    -h|--help) usage; exit 0 ;;
    "")        ;;   # no args — proceed normally
    *) echo "$PROG: unknown option '$1' — try '$PROG --help'" >&2; exit 1 ;;
esac

vpn_is_up || die "${VPN_IFACE} is not up — refusing to start without a VPN tunnel."

kill_previous
ensure_mounts
start_daemon
start_watchdog

log "All done. Use 'tmux attach -t ${TMUX_SESSION}' to watch the daemon,"
log "or 'tmux attach -t ${WATCHDOG_SESSION}' to watch the VPN watchdog."
