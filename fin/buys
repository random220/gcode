#!/usr/bin/env python
import csv
from datetime import datetime
from collections import defaultdict


def parse_date(date_str):
    """Parse a date string in 'mm/dd/yyyy' format to a datetime object."""
    return datetime.strptime(date_str, '%m/%d/%Y')


def parse_month(month_str):
    """Parse a month string in 'YYYY/mm' format to a datetime object."""
    return datetime.strptime(month_str, '%Y/%m')


# Initialize dictionaries to track buy and sell amounts by date using defaultdict for convenience
amounts = {
    'buy': defaultdict(float),
    'sell': defaultdict(float)
}

# Read the input CSV file
with open('input.csv', mode='rt', newline='', encoding='utf-8') as f:
    reader = csv.DictReader(f)
    for row in reader:
        date = row["Run Date"]
        action = row["Action"]
        
        # Determine transaction type and amount
        if 'BOUGHT' in action:
            transaction = 'buy'
            amount = -float(row["Amount ($)"])  # Buys are negative in the CSV, convert to positive
        elif 'SOLD' in action:
            transaction = 'sell'
            amount = float(row["Amount ($)"])
        else:
            continue  # Skip rows that are neither buys nor sells
        
        # Accumulate the amount for the date
        amounts[transaction][date] += amount

# Get all unique dates from buys and sells, sorted chronologically ascending
all_dates = sorted(set(amounts['buy'].keys()) | set(amounts['sell'].keys()), key=parse_date)

# Prepare totals and monthly aggregates
buy_totals = {'total': 0.0, 'monthly': defaultdict(float)}
sell_totals = {'total': 0.0, 'monthly': defaultdict(float)}

# Accumulate totals and monthly amounts
for date in all_dates:
    buys = amounts['buy'][date]
    sells = amounts['sell'][date]
    
    # Update overall totals
    buy_totals['total'] += buys
    sell_totals['total'] += sells
    
    # Get monthly key in 'YYYY/mm' format
    dt = parse_date(date)
    month_key = dt.strftime('%Y/%m')
    
    # Update monthly totals
    buy_totals['monthly'][month_key] += buys
    sell_totals['monthly'][month_key] += sells

# Get all unique months, sorted descending
all_months = sorted(set(buy_totals['monthly'].keys()) | set(sell_totals['monthly'].keys()), key=parse_month, reverse=True)

# Get all dates sorted descending
all_dates_desc = sorted(all_dates, key=parse_date, reverse=True)

# Write to the TSV file: monthly first, then total, then daily
with open('buysell-dollars.tsv', 'wt', encoding='utf-8') as f:
    # Write monthly section
    f.write('Month\tBuys\tSells\n')
    for month in all_months:
        monthly_buys = buy_totals['monthly'][month]
        monthly_sells = sell_totals['monthly'][month]
        f.write(f'{month}\t{monthly_buys:.2f}\t{monthly_sells:.2f}\n')
    
    # Write a blank line separator
    f.write(' \t \t \n')
    
    # Write overall totals
    f.write(f'TOTAL\t{buy_totals["total"]}\t{sell_totals["total"]}\n')
    
    # Write another blank line separator
    f.write(' \t \t \n')
    
    # Write daily section
    f.write('Date\tBuys\tSells\n')
    for date in all_dates_desc:
        buys = amounts['buy'][date]
        sells = amounts['sell'][date]
        f.write(f'{date}\t{buys:.2f}\t{sells:.2f}\n')
